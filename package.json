{
  "name": "project-destiny",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "codex:build": "./scripts/codex-build.sh",
    "codex:test": "./scripts/codex-test.sh",
    "codex:typecheck": "./scripts/codex-typecheck.sh",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:playthrough": "vitest run src/application/playthrough",
    "test:playthrough:golden": "vitest run src/application/playthrough/scenarios/goldenPath.test.ts",
    "test:playthrough:branches": "vitest run src/application/playthrough/scenarios/branchScenarios.test.ts",
    "test:playthrough:funnel": "vitest run src/application/commands/questFunnelPlaythrough.test.ts",
    "test:playthrough:invariants": "vitest run src/application/playthrough/scenarios/eventSystemInvariants.test.ts",
    "test:playthrough:browser": "vitest run src/ui/playthrough",
    "test:playthrough:all": "vitest run src/application/playthrough src/application/commands/questFunnelPlaythrough.test.ts src/ui/playthrough",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "prepare": "simple-git-hooks",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.2",
    "globals": "^17.5.0",
    "jsdom": "^27.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm typecheck"
  }
}
